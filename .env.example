# ===========================================================================
# BREATHE ESG — PRODUCTION ENVIRONMENT VARIABLES CONFIGURATION
# ===========================================================================

# ---------------------------------------------------------------------------
# 💻 BACKEND DEPLOYMENT SETTINGS (RENDER / POSTGRESQL)
# ---------------------------------------------------------------------------

# Django application mode (True for local development, False for production deployment)
DEBUG=False

# Secure private key for crypto signing (Generate a random high-entropy key)
# Example: SECRET_KEY=django-insecure-j67*u!82(91%^8w2!hjsq9*12_jh&21s
SECRET_KEY=your-production-high-entropy-secret-key-goes-here

# Allowed hostnames checking for Django host protection header
# Separate multiple domains with commas. Use * for wildcards if needed (less secure).
# Example: ALLOWED_HOSTS=breathe-esg-backend.onrender.com,localhost
ALLOWED_HOSTS=breathe-esg-backend.onrender.com,localhost

# PostgreSQL connection string containing credentials
# Format: postgres://username:password@hostname:port/databasename
# Example: DATABASE_URL=postgres://breathe_user:secure_pwd@ep-active-water-1234.us-east-1.aws.neon.tech/breathe_db
DATABASE_URL=postgres://username:password@hostname:port/databasename

# Allowed origins list for CORS communication with React frontend
# Separate multiple URLs with commas. Must include the exact Vercel frontend URL!
# Example: CORS_ALLOWED_ORIGINS=https://breathe-esg-frontend.vercel.app,http://localhost:5173
CORS_ALLOWED_ORIGINS=https://your-frontend-vercel-domain.vercel.app,http://localhost:5173

# Enforce secure HTTPS redirection under load balancers (True to force redirects)
SECURE_SSL_REDIRECT=False


# ---------------------------------------------------------------------------
# 🖥️ FRONTEND DEPLOYMENT SETTINGS (VERCEL)
# ---------------------------------------------------------------------------

# Target API gateway URL pointing to the deployed Render backend
# Crucial: Do not include a trailing slash!
# Example: VITE_API_URL=https://breathe-esg-backend.onrender.com
VITE_API_URL=https://your-backend-render-domain.onrender.com
